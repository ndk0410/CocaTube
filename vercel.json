{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.{css,js,html,png,jpg,jpeg,svg,ico,json,webmanifest}",
      "use": "@vercel/static",
      "config": {
        "exclude": [
          "server.js",
          "node_modules/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}